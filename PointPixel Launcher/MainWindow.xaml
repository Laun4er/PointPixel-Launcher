<Window x:Class="PointPixel_Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PointPixel_Launcher"
        mc:Ignorable="d"
        Title="PixelPoint Launcher" MinHeight="600" MinWidth="1000" Background="#1E1E1E" WindowStartupLocation="CenterScreen" >



    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="1"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        
        

        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Window.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="Win">
<!--Разметка-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" x:Name="col1"/>
            <ColumnDefinition Width="*" x:Name="col2"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        
        <Border Grid.RowSpan="3" Background="#2D2D2D" CornerRadius="10" Margin="10,10,4,10" Width="35" x:Name="LeftNavPanel">
            <Border Width="35" Height="35" Margin="0,5" Background="#444444" CornerRadius="5" VerticalAlignment="Top">
                <Image Source="/Assets/PP.png" Margin="2">
                    <Image.ToolTip>
                        <ToolTip Content="PointPixel.ru"/>
                    </Image.ToolTip>
                </Image>
            </Border>
        </Border>
        <Border MouseLeftButtonDown="Border_MouseLeftButtonDown" MouseDown="Border_MouseDown" Grid.Column="1" Background="#3C3C3C" CornerRadius="10" Margin="4,10,10,4"/>
        <Border Grid.ColumnSpan="1" Grid.Column="1" Grid.Row="2" Background="#3C3C3C" CornerRadius="10" Margin="4,4,10,10"/>

        <DockPanel Grid.Column="1" Width="65" Height="15" VerticalAlignment="Top" Margin="5,11,10,4" HorizontalAlignment="Right">
            <Image  x:Name="minimizeButton" MouseLeftButtonDown="minimizeButton_MouseLeftButtonDown" Source="/Assets/Window/minimize.png" Height="15" Width="15" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="NearestNeighbor" VerticalAlignment="Bottom"/>
            <Image  x:Name="maximizeBox" MouseLeftButtonDown="maximizeBox_MouseLeftButtonDown" Source="/Assets/Window/maximize.png" Height="15" Width="15" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="NearestNeighbor" VerticalAlignment="Top"/>
            <Image  x:Name="closeButton" MouseLeftButtonDown="closeButton_MouseLeftButtonDown" Source="/Assets/Window/close.png" Height="15" Width="15" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="NearestNeighbor" VerticalAlignment="Top"/>
        </DockPanel>

        <ListBox x:Name="Mainwin" Grid.Row="1" Width="35" Background="Transparent" Margin="10,0,4,0">
            <ListBoxItem x:Name="Main" Margin="0,0,0,15">
                <Image Source="/Assets/ListBox Static/Main.png" Width="30" Height="30" HorizontalAlignment="Left"/>
            </ListBoxItem>
            <ListBoxItem x:Name="Parametres">
                <Image Source="/Assets/ListBox Static/Parametres.png" Width="30" Height="30"/>
            </ListBoxItem>
        </ListBox>
        
    </Grid>
</Window>
