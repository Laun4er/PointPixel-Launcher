<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>PointPixel_Launcher</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Assets\PP.png" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="PP lib">
      <HintPath>..\..\PP lib\PP lib\bin\Debug\net8.0-windows\PP lib.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\PP.png" />
  </ItemGroup>

</Project>
